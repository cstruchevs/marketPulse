# Database
DATABASE_URL=postgresql://mp_user:mp_secret@localhost:5432/market_pulse

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here

# Scraper
SCRAPER_API_KEY=your-scraperapi-key-here

# AWS
AWS_REGION=us-east-1
S3_BUCKET_NAME=market-pulse-assets
S3_BUCKET_EXPORTS=market-pulse-private

# AWS SES
AWS_SES_FROM_EMAIL=alerts@yourdomain.com

# Frontend
FRONTEND_URL=http://localhost:5173

# App
NODE_ENV=development

# Anthropic (for MCP / Claude AI analysis)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# LocalStack (local AWS emulation)
LOCALSTACK_ENDPOINT=http://localhost:4566
